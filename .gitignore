# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# cloudflare wrangler / pages build artifacts
# These are generated by next-on-pages and contain `var self = this` patterns
# that trip @typescript-eslint/no-this-alias and fail CI if scanned.
.wrangler/

# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
/test
prompt

server.log
# Skills directory
/skills/.wrangler/
upload/
tool-results/

# Build-time generated repo index (committed for Cloudflare Pages, regenerated on each build)
# public/repo-index.json

# Plugin SDK — generated registry
src/lib/plugin-sdk/plugin-registry.generated.ts
